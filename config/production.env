# Production Environment Configuration
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Security Settings (Production - CHANGE THESE VALUES)
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_DEPLOYMENT
ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/aboa-prod.log

# Database Settings (Production - CHANGE THESE VALUES)
DATABASE_URL=postgresql://username:password@db-host:5432/aboa_prod
VECTOR_DB_URL=http://vector-db-host:8000
VECTOR_DB_COLLECTION=aboa_knowledge_prod

# External Integrations (Production - CHANGE THESE VALUES)
N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook
N8N_API_KEY=CHANGE_THIS_N8N_API_KEY

# Business Settings
DEFAULT_FOLLOW_UP_DAYS=3
SLA_BREACH_THRESHOLD_HOURS=24
HIGH_VALUE_DEAL_THRESHOLD=10000.0

# Retry and Timeout Settings
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2
ACTION_TIMEOUT_SECONDS=300
APPROVAL_TIMEOUT_HOURS=24