# Development Environment Configuration
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security Settings (Development)
SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# Logging Settings
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_FILE=logs/aboa-dev.log

# Database Settings
DATABASE_URL=sqlite:///./data/aboa_dev.db
VECTOR_DB_URL=http://localhost:8001
VECTOR_DB_COLLECTION=aboa_knowledge_dev

# External Integrations
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=dev-n8n-api-key

# Business Settings
DEFAULT_FOLLOW_UP_DAYS=1
SLA_BREACH_THRESHOLD_HOURS=4
HIGH_VALUE_DEAL_THRESHOLD=5000.0

# Retry and Timeout Settings
MAX_RETRIES=2
RETRY_DELAY_SECONDS=1
ACTION_TIMEOUT_SECONDS=60
APPROVAL_TIMEOUT_HOURS=2