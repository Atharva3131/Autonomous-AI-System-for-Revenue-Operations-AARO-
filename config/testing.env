# Testing Environment Configuration
ENVIRONMENT=testing
DEBUG=false
HOST=127.0.0.1
PORT=8001

# Security Settings (Testing)
SECRET_KEY=test-secret-key-for-ci
ALLOWED_ORIGINS=http://localhost:3000

# Logging Settings
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_FILE=

# Database Settings
DATABASE_URL=sqlite:///:memory:
VECTOR_DB_URL=http://localhost:8001
VECTOR_DB_COLLECTION=aboa_knowledge_test

# External Integrations (Mock)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/test
N8N_API_KEY=test-n8n-api-key

# Business Settings (Fast testing)
DEFAULT_FOLLOW_UP_DAYS=1
SLA_BREACH_THRESHOLD_HOURS=1
HIGH_VALUE_DEAL_THRESHOLD=1000.0

# Retry and Timeout Settings (Fast testing)
MAX_RETRIES=1
RETRY_DELAY_SECONDS=0
ACTION_TIMEOUT_SECONDS=10
APPROVAL_TIMEOUT_HOURS=1