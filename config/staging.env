# Staging Environment Configuration
ENVIRONMENT=staging
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Security Settings (Staging)
SECRET_KEY=staging-secret-key-change-before-prod
ALLOWED_ORIGINS=https://staging.your-domain.com,http://localhost:3000

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/aboa-staging.log

# Database Settings
DATABASE_URL=postgresql://username:password@staging-db-host:5432/aboa_staging
VECTOR_DB_URL=http://staging-vector-db-host:8000
VECTOR_DB_COLLECTION=aboa_knowledge_staging

# External Integrations
N8N_WEBHOOK_URL=https://staging-n8n.your-domain.com/webhook
N8N_API_KEY=staging-n8n-api-key

# Business Settings
DEFAULT_FOLLOW_UP_DAYS=2
SLA_BREACH_THRESHOLD_HOURS=12
HIGH_VALUE_DEAL_THRESHOLD=7500.0

# Retry and Timeout Settings
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1
ACTION_TIMEOUT_SECONDS=180
APPROVAL_TIMEOUT_HOURS=12